{
  "name": "converter",
  "version": "1.7.2",
  "description": "Convert images, audio, video, documents, 3D models & animations",
  "main": "main.js",
  "author": "Converter App <converter@app.com>",
  "license": "MIT",
  "scripts": {
    "start": "electron .",
    "dev": "electron . --dev",
    "build": "electron-builder",
    "build:mac": "electron-builder --mac",
    "build:win": "electron-builder --win",
    "build:linux": "electron-builder --linux",
    "release": "electron-builder --publish always",
    "postinstall": "electron-builder install-app-deps"
  },
  "build": {
    "appId": "com.converter.app",
    "productName": "Converter",
    "directories": {
      "output": "dist"
    },
    "files": [
      "main.js",
      "preload.js",
      "converter.js",
      "index.html",
      "styles.css",
      "renderer.js",
      "package.json",
      "scripts/**/*",
      "build-assets/**/*",
      "node_modules/**/*"
    ],
    "asarUnpack": [
      "node_modules/@ffmpeg-installer/**"
    ],
    "afterPack": "scripts/afterPack.js",
    "mac": {
      "target": [
        {
          "target": "dmg",
          "arch": [
            "x64",
            "arm64"
          ]
        },
        {
          "target": "zip",
          "arch": [
            "x64",
            "arm64"
          ]
        }
      ],
      "category": "public.app-category.utilities",
      "icon": "build-assets/icon.png",
      "artifactName": "${name}-${version}-mac-${arch}.${ext}",
      "gatekeeperAssess": false,
      "hardenedRuntime": false
    },
    "win": {
      "target": [
        {
          "target": "nsis",
          "arch": [
            "x64"
          ]
        },
        {
          "target": "portable",
          "arch": [
            "x64"
          ]
        }
      ],
      "icon": "build-assets/icon.png",
      "artifactName": "${name}-${version}-win-${arch}.${ext}"
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true
    },
    "linux": {
      "target": [
        {
          "target": "AppImage",
          "arch": [
            "x64"
          ]
        },
        {
          "target": "deb",
          "arch": [
            "x64"
          ]
        }
      ],
      "category": "Utility",
      "icon": "build-assets/icon.png",
      "artifactName": "${name}-${version}-linux-${arch}.${ext}"
    },
    "publish": {
      "provider": "github",
      "owner": "Bobbyyyyyyyya",
      "repo": "Converter",
      "releaseType": "release"
    }
  },
  "keywords": [
    "converter",
    "electron",
    "image",
    "audio",
    "video",
    "cross-platform"
  ],
  "dependencies": {
    "@ffmpeg-installer/ffmpeg": "^1.1.0",
    "adm-zip": "^0.5.18",
    "assimpjs": "^0.0.10",
    "electron-updater": "^6.0.0",
    "fluent-ffmpeg": "^2.1.3",
    "lottie-web": "^5.13.0",
    "mammoth": "^1.12.0",
    "pdfjs-dist": "^6.1.200",
    "pdfkit": "^0.19.1",
    "sharp": "^0.35.3"
  },
  "devDependencies": {
    "@electron/osx-sign": "^2.5.0",
    "electron": "^43.0.0",
    "electron-builder": "^26.15.3"
  },
  "allowScripts": {
    "@ffmpeg-installer/darwin-arm64@4.1.5": true
  }
}
